{
  "name": "sproutkit",
  "version": "0.1.0",
  "description": "Scaffold ready-to-use project structures from templates, skipping boilerplate",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "prepare": "husky",
    "start": "node dist/index.js",
    "build": "rollup -c",
    "build:prod": "rollup -c --environment NODE_ENV:production",
    "lint": "eslint . && codecap --check && prettier --check \"**/*.{json,md,yml}\"",
    "format": "eslint . --fix && codecap --fix && prettier --write \"**/*.{json,md,yml}\""
  },
  "dependencies": {
    "commander": "^14.0.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@rollup/plugin-replace": "^6.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/node": "^24.10.1",
    "codecap": "^0.3.1",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "jiti": "^2.6.1",
    "lint-staged": "^16.2.6",
    "prettier": "^3.6.2",
    "rollup": "^4.53.2",
    "rollup-plugin-delete": "^3.0.1",
    "rollup-plugin-prettier": "^4.1.2",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.4"
  }
}
